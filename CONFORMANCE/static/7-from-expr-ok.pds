// LANG.md §7.2 (ADR-035): `Type from Expr` is well-formed when the source's type
// satisfies the target. A `Cat` composed from a `Cat`-returning call is clean.

//! example

public data Cat;

public system Zoo;

public container Pen for Zoo {
  AdoptCat(): Cat { return Cat from self.MakeCat() }
  MakeCat(): Cat;
}
