// LANG.md §7.1 (ADR-002): bindings are single-assignment. The second
// assignment to `r` re-binds a name and is a model error.

//! example

public data Info { id: number }

public system Banking;

public container Mainframe for Banking {
  Run(): void {
    r: Info = self.Make()
    r: Info = self.Make()
  }
  Make(): Info;
}
