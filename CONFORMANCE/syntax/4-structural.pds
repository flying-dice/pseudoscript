// LANG.md §4: flat structure. `system` is top-level; `container`/`component`
// name their parent with `for`. Each discloses with a block or is a black box
// with `;`. `public` is the only modifier.

public person Customer;

public system Banking;

public system Monica;

public container Mainframe for Banking {
}

public container AccountStore for Banking;

component AccountService for Mainframe {
}

component Repository for AccountStore;
