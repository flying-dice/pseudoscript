// LANG.md §7.5 / §10 (ADR-038): an `if`/`while` condition may use comparison and
// boolean operators; a constant is referenced by its FQN (§3.6).

//! example

public constant LIMIT = 100

public system S;

public container C for S {
  guard(x: number): void {
    if (x < app::LIMIT && x > 0 && x >= 0) { }
  }
}
