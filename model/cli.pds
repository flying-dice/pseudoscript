//! cli — the `pds` binary; loads `pds.toml` and drives the library crates (crate
//! `pseudoscript`).
//!
//! The composition root and the sole I/O edge: every other context is pure over
//! in-memory modules, while file reading/writing, HTTP serving, filesystem
//! watching, and dependency fetching live here. Workspace loading delegates to
//! `project`; I/O failures travel back to the process exit code.
//! Command surface:
//! pds init    [path] [--name N]                       bootstrap a workspace
//! pds doc     [path] [--serve] [--watch] [--all] [--format html|md]   headline (ADR-017)
//! pds check   [path] [--all]                          diagnostics; non-zero on error
//! pds eval                                            stdin diagnostics; non-zero on error
//! pds fmt     <file.pds> [--write]                    canonical formatting
//! pds tokens  <file.pds>                              lexical token stream
//! pds outline [path]                                  workspace symbol outline as JSON
//! pds svg     [path] [--symbol F | --view V --target T] [--theme]   one diagram to SVG
//! pds lsp                                             language server over stdio
//! pds lang | skill                                    print the language reference / authoring skill
//! pds add <url> | install | update | remove <name> | list [root]    dependency management (§8.3)
//! pds upgrade [version]                               self-update the binary

/// The subcommand clap parsed from argv, with its resolved options.
public data Command =
  | InitCmd { path: string, name: string }
  | DocOpts { path: string, serve: bool, watch: bool, port: number, all: bool, format: string }
  | CheckOpts { file: string, all: bool }
  | EvalOpts
  | FmtOpts { file: string, write: bool }
  | TokensOpts { file: string }
  | OutlineOpts { path: string }
  | SvgOpts { path: string, symbol: string, view: string, target: string, theme: string }
  | LspOpts
  | LangOpts
  | SkillOpts
  | AddOpts { url: string, tag: string, rev: string, branch: string, path: string, name: string }
  | InstallOpts
  | UpdateOpts
  | RemoveOpts { name: string }
  | ListOpts { root: string }
  | UpgradeOpts { version: string }

/// The loaded project: the `[doc]` config, the resolved output directory
/// (`<root>/<out>`, default `target/doc`), every module sorted by FQN, the
/// dependency-name-prefixed dependency modules (§8.3; empty without a `pds.lock`),
/// and the preferred doc output format. Produced from the nearest `pds.toml`.
public data Workspace { config: doc::DocConfig, outDir: string, modules: model::WorkspaceModule[], dependencies: model::WorkspaceModule[], format: string }

/// A filesystem, parse-config, or serving failure surfaced to the CLI exit code.
public data IoError { message: string }

/// `crates/pseudoscript` — the binary crate (`pds`). The composition root and
/// only I/O edge; a thin frontend that wires the pure library crates to disk,
/// HTTP, and a filesystem watcher.
public container Cli for context::Pseudoscript {
  /// Generate the documentation site for the workspace containing `path`.
  public runDoc(path: string): Result<void, cli::IoError> {
    return cli::DocCmd.run(path)
  }

  /// Boot the language server over stdio.
  public runLsp(): Result<void, cli::IoError> {
    return cli::LspHost.run()
  }
}

/// Parses argv with clap-derive into the chosen subcommand and its options, then
/// dispatches to the matching command handler.
component Args for cli::Cli {
  /// Parse argv into a `Command`; clap reports usage errors itself.
  parse(argv: string[]): cli::Command;
  /// Route a parsed `Command` to its handler, returning the process exit code.
  #[manual]
  dispatch(command: cli::Command): number;
}

/// The CLI loader: resolves the project root and reads its modules through the
/// `project` crate (the shared filesystem edge), then parses the cli-specific
/// `[doc]` table on top. Root-finding and module-walking are `project`'s job;
/// the manifest's doc config is the CLI's.
component Loader for cli::Cli {
  /// Walk the ancestors of `start` to the nearest directory holding `pds.toml`,
  /// delegating to `project`; no `pds.toml` anywhere is an error.
  findRoot(start: string): Result<string, cli::IoError> {
    found = Result<string, project::IoError> from project::Project.findRoot(start)
    if (found.isErr) {
      return Err(self.ioError(found.error))
    }
    return Ok(found.value)
  }

  /// Load the project rooted at `root`: parse the manifest and collect modules.
  load(root: string): Result<cli::Workspace, cli::IoError> {
    config = Result<Workspace, IoError> from self.loadManifest(root)
    if (config.isErr) {
      return Err(config.error)
    }
    modules = Result<model::WorkspaceModule[], IoError> from self.loadModules(root)
    if (modules.isErr) {
      return Err(modules.error)
    }
    project = Workspace from { config.value, root, modules.value }
    return Ok(project)
  }

  /// Read `<root>/pds.toml` and map its `[doc]` table into a `DocConfig` plus the
  /// resolved output directory; an unknown `theme` is rejected.
  loadManifest(root: string): Result<cli::Workspace, cli::IoError>;

  /// Read every `.pds` module under `root` through `project`, sorted by FQN.
  loadModules(root: string): Result<model::WorkspaceModule[], cli::IoError> {
    loaded = Result<model::WorkspaceModule[], project::IoError> from project::Project.load(root)
    if (loaded.isErr) {
      return Err(self.ioError(loaded.error))
    }
    return Ok(loaded.value)
  }

  /// Lift a `project` I/O failure into the CLI's exit-code error.
  ioError(e: project::IoError): cli::IoError;
}

/// `pds init` — bootstrap a workspace: write `pds.toml` and a starter `main.pds`.
/// Refuses to overwrite an existing manifest; the starter is written only when
/// absent.
component InitCmd for cli::Cli {
  #[manual]
  public run(path: string, name: string): Result<void, cli::IoError> {
    exists = Result<bool, IoError> from self.manifestExists(path)
    if (exists.isErr) {
      return Err(exists.error)
    }
    return self.writeFiles(path, name)
  }

  /// Whether `<path>/pds.toml` already exists — refuse to clobber a workspace.
  manifestExists(path: string): Result<bool, cli::IoError>;

  /// Create the directory, write `pds.toml`, then the starter module if absent.
  writeFiles(path: string, name: string): Result<void, cli::IoError>;
}

/// `pds doc` — the headline command (ADR-017). Load the workspace, check it
/// (reported but non-fatal, like `cargo doc`), project the resolved graph, render
/// a static doc site with embedded C4 and sequence SVGs, and write it. `--serve`
/// hosts it over HTTP; `--watch` adds a filesystem watcher and browser live
/// reload.
/// #headline
component DocCmd for cli::Cli {
  /// Generate the documentation site for the workspace containing `path`.
  /// Invoked by the Developer (`context::Developer.renderDocs`).
  /// #headline
  public run(path: string): Result<void, cli::IoError> {
    root = Result<string, IoError> from cli::Loader.findRoot(path)
    if (root.isErr) {
      return Err(root.error)
    }
    project = Result<Workspace, IoError> from cli::Loader.load(root.value)
    if (project.isErr) {
      return Err(project.error)
    }
    diagnostics = syntax::Diagnostic[] from model::Model.checkWorkspace(project.value.modules)
    self.report(diagnostics)
    graph = Graph from model::Model.graph(project.value.modules)
    site = Result<Site, RenderError> from doc::Doc.render(graph, project.value.config)
    written = Result<void, IoError> from self.write(site.value, project.value.outDir)
    if (written.isErr) {
      return Err(written.error)
    }
    self.copyLogo(root.value, project.value)
    return Ok
  }

  /// Generate once, then optionally serve — with a watcher and live reload when
  /// `watch` is set. `watch` implies `serve`.
  #[manual]
  public serve(path: string, serve: bool, watch: bool, port: number): Result<void, cli::IoError> {
    built = Result<void, IoError> from self.run(path)
    if (built.isErr) {
      return Err(built.error)
    }
    if (watch) {
      cli::Watcher.watch(path, port)
    }
    return cli::HttpServer.serve(path, port, watch)
  }

  /// Write each `SiteFile` under the output directory, creating parent dirs.
  write(site: doc::Site, outDir: string): Result<void, cli::IoError>;

  /// Print each workspace diagnostic to stderr as `severity: message`; never
  /// fatal — a partial model still documents.
  report(diagnostics: syntax::Diagnostic[]): void;

  /// Copy the configured logo into the output dir, relative to the root. A
  /// missing logo warns but does not fail.
  copyLogo(root: string, project: cli::Workspace): void;
}

/// `pds check` — parse and statically check one file, print each diagnostic as
/// `path:line:col: severity: message`, and exit non-zero on any error-severity
/// diagnostic. Emits no diagram.
component CheckCmd for cli::Cli {
  #[manual]
  public run(text: string): Result<void, cli::IoError> {
    diagnostics = syntax::Diagnostic[] from model::Model.check(text)
    if (self.anyError(diagnostics)) {
      err = IoError from { diagnostics }
      return Err(err)
    }
    return Ok
  }

  /// Whether any diagnostic is error-severity — the non-zero-exit signal.
  anyError(diagnostics: syntax::Diagnostic[]): bool;
}

/// `pds eval` — read a model from stdin and statically check it, printing each
/// diagnostic as `<stdin>:line:col: severity: message` and exiting non-zero on
/// any error. The fileless path: an agent pipes a snippet to check it without
/// writing a file.
component EvalCmd for cli::Cli {
  #[manual]
  public run(text: string): Result<void, cli::IoError> {
    diagnostics = syntax::Diagnostic[] from model::Model.check(text)
    if (self.anyError(diagnostics)) {
      err = IoError from { diagnostics }
      return Err(err)
    }
    return Ok
  }

  /// Whether any diagnostic is error-severity — the non-zero-exit signal.
  anyError(diagnostics: syntax::Diagnostic[]): bool;
}

/// `pds fmt` — format to canonical PseudoScript; `--write` overwrites the file in
/// place, otherwise prints to stdout. A parse error is reported and the file is
/// left untouched.
component FmtCmd for cli::Cli {
  #[manual]
  public run(text: string, write: bool): Result<void, format::FormatError> {
    out = Result<string, FormatError> from format::Format.format(text)
    if (out.isErr) {
      return Err(out.error)
    }
    if (write) {
      self.overwrite(out.value)
    } else {
      self.print(out.value)
    }
    return Ok
  }

  /// Overwrite the source file in place with the canonical text.
  overwrite(formatted: string): void;
  /// Print the canonical text to stdout.
  print(formatted: string): void;
}

/// `pds tokens` — print the conformance token stream (`KIND@line:col "lexeme"`)
/// to stdout, for debugging the lexer.
component TokensCmd for cli::Cli {
  #[manual]
  public run(text: string): Result<void, cli::IoError> {
    stream = string from syntax::Syntax.renderTokens(text)
    self.print(stream)
    return Ok
  }

  /// Print the rendered token stream to stdout.
  print(stream: string): void;
}

/// `pds lsp` — boot a Tokio runtime and launch the language server over stdio.
/// Spawned as a child process by an editor (`context::Editor.openDocument`).
component LspHost for cli::Cli {
  public run(): Result<void, cli::IoError> {
    lsp::Lsp.runStdio()
    return Ok
  }
}

/// `pds lang` (alias `spec`) and `pds skill` — print the bundled, version-pinned
/// language reference and the authoring skill to stdout. Fed to an LLM to author
/// `.pds`; no workspace needed.
component ReferenceCmd for cli::Cli {
  /// Print the bundled language reference (spec, patterns, conformance/grammar).
  #[manual]
  lang(): void;
  /// Print the bundled authoring skill — the method for modelling with `.pds`.
  #[manual]
  skill(): void;
}

/// `pds outline` — load the workspace, build its graph, and print the symbol
/// outline as JSON: each node's `fqn`, `name`, `kind`, `parent`, whether it is a
/// triggered flow entry, and its declaration site. The structure tree an editor
/// draws.
component OutlineCmd for cli::Cli {
  #[manual]
  public run(path: string): Result<void, cli::IoError> {
    root = Result<string, IoError> from cli::Loader.findRoot(path)
    if (root.isErr) {
      return Err(root.error)
    }
    project = Result<Workspace, IoError> from cli::Loader.load(root.value)
    if (project.isErr) {
      return Err(project.error)
    }
    graph = Graph from model::Model.graph(project.value.modules)
    self.print(self.render(graph))
    return Ok
  }

  /// Serialise each graph node to an outline row — fqn, name, kind, parent, the
  /// triggered-flow flag, and its declaration module/line/col — as JSON.
  render(graph: model::Graph): string;

  /// Print the outline JSON to stdout.
  print(json: string): void;
}

/// `pds svg` — render a single diagram to a self-contained SVG on stdout. With
/// `--symbol`, draws that symbol's fitting view; otherwise draws `--view` (paired
/// with `--target`) over the whole workspace. The static counterpart of the IDE
/// canvas.
component SvgCmd for cli::Cli {
  #[manual]
  public run(path: string, symbol: string, view: string, target: string, theme: string): Result<void, cli::IoError> {
    root = Result<string, IoError> from cli::Loader.findRoot(path)
    if (root.isErr) {
      return Err(root.error)
    }
    project = Result<Workspace, IoError> from cli::Loader.load(root.value)
    if (project.isErr) {
      return Err(project.error)
    }
    graph = Graph from model::Model.graph(project.value.modules)
    scene = Result<Scene, EmitError> from self.projectChosen(graph, symbol, view, target)
    if (scene.isErr) {
      return Err(self.emitError(scene.error))
    }
    self.print(emit::Emit.render(scene.value))
    return Ok
  }

  /// Pick the view from `--symbol` or `--view`/`--target` and project it.
  projectChosen(graph: model::Graph, symbol: string, view: string, target: string): Result<emit::Scene, emit::EmitError>;

  /// Lift an emit projection failure into the CLI's exit-code error.
  emitError(e: emit::EmitError): cli::IoError;

  /// Print the SVG document to stdout.
  print(svg: string): void;
}

/// `pds add`/`install`/`update`/`remove`/`list` — git workspace dependency
/// management (§8.3). `add` resolves a git URL into `pds.toml` + `pds.lock` and
/// vendors it; `install` restores `pds_modules/` from the lock; `update`
/// re-pins; `remove` drops one; `list` discovers every workspace under a root.
/// Resolution delegates to `project`; fetching is the CLI's I/O.
component Deps for cli::Cli {
  /// Add a git dependency: pin it in `pds.toml`/`pds.lock` and vendor its modules.
  #[manual]
  add(url: string, tag: string, rev: string, branch: string, path: string, name: string): Result<void, cli::IoError>;

  /// Restore `pds_modules/` from `pds.lock`.
  #[manual]
  install(): Result<void, cli::IoError>;

  /// Re-resolve git dependencies, repinning `pds.lock` to current commits.
  #[manual]
  update(): Result<void, cli::IoError>;

  /// Remove a dependency from `pds.toml` and `pds.lock`.
  #[manual]
  remove(name: string): Result<void, cli::IoError>;

  /// List every `pds.toml` workspace under a root directory.
  #[manual]
  list(root: string): Result<void, cli::IoError>;
}

/// `pds upgrade` — download a release and install it over the running binary.
component UpgradeCmd for cli::Cli {
  /// Install the named release (default: latest) over the current binary.
  #[manual]
  run(version: string): Result<void, cli::IoError>;
}

/// HTTP host for the generated site (`--serve`/`--watch`): `tiny_http` on
/// `127.0.0.1:port`, maps `/` to `index.html`, rejects paths escaping the output
/// dir, and on watch injects a live-reload poll and answers `/__livereload` with
/// the current version. Blocks until the process is stopped.
component HttpServer for cli::Cli {
  /// Serve the workspace's output dir until stopped. A browser is the client;
  /// `reload` instruments HTML and serves the version endpoint.
  #[http("GET /")]
  serve(path: string, port: number, reload: bool): Result<void, cli::IoError>;
}

/// Filesystem watcher (`--watch`, via `notify`): watches the project root
/// recursively, debounces each save burst, and on a relevant change rebuilds the
/// site and bumps the version the browser's live-reload poll reads. Events under
/// the output dir are ignored so writing the site never re-triggers a build.
component Watcher for cli::Cli {
  /// Block watching the root, rebuilding and bumping the live-reload version on
  /// each relevant change. Runs on a detached thread.
  watch(root: string, port: number): Result<void, cli::IoError>;

  /// Whether a changed path should trigger a rebuild: a `.pds` file or `pds.toml`
  /// not under the generated output dir.
  isSourceChange(path: string, outDir: string): bool;
}

/// The CLI is the composition root and the only I/O edge.
feature CompositionRoot for cli::Cli {
  given "the library crates that are pure over in-memory modules"
  when "the CLI runs any subcommand"
  then "all file reading, writing, HTTP serving, and watching happen in the CLI"
  and "the pure core receives module text and returns values"
  but "I/O and load failures are the only things that fail a command, via the exit code"
}

/// argv is parsed into one subcommand and dispatched.
feature ParseSubcommand for cli::Cli {
  given "a command line for one of init, doc, check, eval, fmt, tokens, outline, svg, lsp, lang, skill, add, install, update, remove, list, or upgrade"
  when "the CLI starts"
  then "clap parses argv into the chosen subcommand and its options"
  and "the matching command handler is invoked"
  but "an unrecognised command or bad option is rejected with a usage error"
}

/// `pds outline` prints the workspace symbol tree as JSON.
feature OutlineAsJson for cli::OutlineCmd {
  given "a workspace under the path"
  when "the developer runs `pds outline`"
  then "the workspace loads and its graph is built"
  and "each node's fqn, name, kind, parent, triggered flag, and declaration site is printed as JSON"
}

/// `pds svg` renders one diagram to a self-contained SVG.
feature RenderOneSvg for cli::SvgCmd {
  given "a workspace and either a --symbol or a --view/--target selection"
  when "the developer runs `pds svg`"
  then "the chosen view is projected and rendered to a standalone SVG on stdout"
  but "a missing or wrong-kind target fails non-zero with the projection error"
}

/// Dependency commands manage git workspaces via pds.toml and pds.lock (§8.3).
feature ManageDependencies for cli::Deps {
  given "a workspace declaring git dependencies"
  when "the developer runs add, install, update, remove, or list"
  then "add pins and vendors a dependency, install restores from the lock, update re-pins, remove drops one"
  and "resolution delegates to the project crate while fetching is the CLI's I/O"
}

/// `pds lang`/`pds skill` print the bundled reference and authoring skill.
feature PrintReference for cli::ReferenceCmd {
  given "no workspace is needed"
  when "the developer runs `pds lang` or `pds skill`"
  then "the version-pinned language reference or the authoring skill is printed to stdout"
}

/// `pds init` bootstraps a workspace and refuses to clobber an existing one.
feature InitWorkspace for cli::InitCmd {
  given "a target directory with no pds.toml"
  when "the developer runs `pds init`"
  then "the directory is created if absent"
  and "a pds.toml carrying a [doc] table is written"
  and "a starter main.pds is written when none exists"
  but "an existing pds.toml aborts the command without overwriting it"
}

/// `pds doc` runs the headline pipeline end to end.
feature DocPipeline for cli::DocCmd {
  given "a project rooted at a pds.toml with one or more .pds modules"
  when "the developer runs `pds doc`"
  then "the workspace is loaded and checked"
  and "the resolved graph is built and rendered to a site"
  and "every site file is written under the output directory"
  and "the configured logo is copied beside the site"
}

/// The project root is found by walking up to the nearest pds.toml.
feature ResolveProjectRoot for cli::Loader {
  given "a path somewhere inside a project tree"
  when "the CLI loads the workspace"
  then "it walks ancestor directories to the nearest pds.toml"
  and "the [doc] config and every .pds module beneath it load, sorted by FQN"
  but "a tree with no pds.toml is an error"
}

/// The workspace check is reported but never aborts generation.
feature CheckIsNonFatal for cli::DocCmd {
  given "a workspace whose model has warnings or errors"
  when "the developer runs `pds doc`"
  then "every diagnostic is printed to stderr"
  but "generation continues like `cargo doc`, so a partial model still documents"
  and "only an I/O or load failure exits non-zero"
}

/// `pds doc --serve` hosts the generated site over HTTP on localhost.
feature ServeOverHttp for cli::HttpServer {
  given "a generated documentation site"
  when "the developer runs `pds doc --serve`"
  then "the site is hosted over HTTP on 127.0.0.1 at the chosen port"
  and "`/` maps to index.html"
  but "a request path that escapes the output directory yields 404"
}

/// `pds doc --watch` rebuilds on change and live-reloads the browser.
feature WatchAndLiveReload for cli::Watcher {
  given "a site served with `--watch`"
  when "a .pds file or pds.toml under the root changes"
  then "the watcher debounces the save burst and rebuilds the site"
  and "the live-reload version is bumped"
  and "the browser, polling /__livereload, reloads to the new version"
  but "writes under the output directory are ignored so the build does not loop"
}

/// `pds check` exits non-zero when any error diagnostic is produced.
feature CheckExitCode for cli::CheckCmd {
  given "a .pds source file"
  when "the developer runs `pds check` on it"
  then "every diagnostic is printed as path:line:col: severity: message"
  but "the command exits non-zero if any diagnostic is error-severity"
  and "a well-formed model prints nothing and exits zero"
}

/// `pds eval` reads stdin and exits non-zero when any error diagnostic is produced.
feature EvalExitCode for cli::EvalCmd {
  given "a model piped to stdin"
  when "the developer or an agent runs `pds eval`"
  then "every diagnostic is printed as <stdin>:line:col: severity: message"
  but "the command exits non-zero if any diagnostic is error-severity"
  and "a well-formed model prints nothing and exits zero"
}

/// `pds fmt --write` overwrites in place; otherwise it prints.
feature FormatInPlaceOrStdout for cli::FmtCmd {
  given "a .pds source file"
  when "the developer runs `pds fmt`"
  then "the source is parsed and pretty-printed to canonical PseudoScript"
  and "with `--write` the file is overwritten in place"
  but "without `--write` the canonical text is printed to stdout"
  and "unparseable source is reported and the file is left untouched"
}

/// `pds tokens` prints the conformance token stream.
feature PrintTokenStream for cli::TokensCmd {
  given "a .pds source file"
  when "the developer runs `pds tokens`"
  then "the lexical token stream is printed as KIND@line:col \"lexeme\""
}

/// `pds lsp` launches the language server over stdio.
feature LaunchLanguageServer for cli::LspHost {
  given "an editor that speaks the Language Server Protocol"
  when "the editor spawns `pds lsp` as a child process"
  then "a Tokio runtime boots and the server runs over stdio"
  and "the editor drives it with document changes and renders its diagnostics"
}
