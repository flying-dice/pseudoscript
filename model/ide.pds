//! ide — the browser IDE (web-ide/, ide.pdscript.dev): ports and adapters.
//!
//! The IDE is **one** Rust crate compiled to **one** WebAssembly artifact —
//! `IdeSession` (`crates/pseudoscript-ide`). It holds the workspace and answers
//! every query the editor drives: language intelligence, diagram projection, the
//! 3D universe, and the doc site. It consumes the toolchain (`lsp_core`, `model`,
//! `emit`, `doc`, `universe`) as ordinary Rust libraries — not a second wasm — so
//! there is one surface in the browser and no risk of a bridge drifting from the
//! app that uses it.
//!
//! The boundary is **typed**: each method takes and returns Rust DTOs that
//! `tsify` projects to TypeScript interfaces, so values cross as objects, not
//! JSON strings the host re-parses against hand-written types. The render IR
//! `Scene` is the one exception — an opaque JSON string the canvas reads
//! structurally.
//!
//! Layers, top to bottom:
//! WebIde (JS adapters)  →  IdeSession (the one Rust wasm)  →  lsp_core / model / emit / doc / universe
//!
//! The arrows that matter: the session *uses* the toolchain libraries for all
//! language and projection logic; the JS adapters *push state in*
//! (`mount`/`setSource`) and *pull typed values out* — the session never calls
//! the browser. JS exists only in those adapters (File System Access,
//! CodeMirror, the canvas), plus the one workspace rule the host runs before
//! mounting: deriving each module's flat FQN from its path (LANG.md §8.1,
//! ADR-031). The one outbound seam is the doc build's SSR render callback.

/// A completion candidate offered as the author types: the inserted label, the
/// integer LSP `CompletionItemKind` the editor maps to an icon, and detail text
/// (absent for candidates with nothing to add).
public data Completion { label: string, kind: number, detail: Option<string> }

/// The in-browser workspace state the session holds: the open `.pds` modules, the
/// `pds.toml` manifest text, and the dependency modules resolved from
/// `pds_modules/` as externals (LANG.md §8.3). Held in memory — a decoded
/// sample/share link or a local directory loaded through the file-system port.
/// Edits never leave the tab.
public data BrowserWorkspace { modules: model::WorkspaceModule[], manifest: string, externals: model::WorkspaceModule[] }

/// One vendored git-dependency file the host reads for `dependencyModules`: its
/// `pds_modules/` slug, its FQN within the dependency workspace (the host's
/// path→FQN derivation, LANG.md §8.1), and its source.
public data VendoredInput { slug: string, fqn: string, source: string }

/// One local-source dependency file the host reads for `dependencyModules`: the
/// dependency name (ADR-026), its FQN within the dependency workspace, and its
/// source.
public data LocalInput { name: string, fqn: string, source: string }

/// One node in the 3D relationship graph the IDE draws: its FQN, C4 level, and
/// containment parent (absent on roots). The typed boundary form of a
/// `universe::NodeOut`.
public data UniverseNode { id: string, level: string, parent: Option<string> }

/// One directed relationship in the 3D graph, weighted by traffic (call count).
/// The wire field is `from`; `from` is a PseudoScript keyword, so the model
/// names it `source`.
public data UniverseEdge { source: string, to: string, traffic: number }

/// The 3D-view snapshot the session hands the `ForceGraph`: nodes and directed
/// weighted edges, no positions (the renderer lays them out). The typed boundary
/// form of a `universe::Snapshot`.
public data UniverseSnapshot { nodes: ide::UniverseNode[], edges: ide::UniverseEdge[] }

/// The IDE's per-diagram C4 layout toggles, crossing to JS as a typed object: run
/// the long-edge optimiser, the reading `orientation` (`"tb"`/`"lr"`), a `spacing`
/// preset (`"compact"`/`"comfortable"`/`"roomy"`), and the experimental grid dials
/// and pins. Translated to `emit::C4Tweaks` inside the session.
public data LayoutTweaks { minimizeLongEdges: bool, orientation: string, spacing: string, experimentalGrid: bool, gridCrossingCost: number, gridDistanceCost: number, gridFlowCost: number, gridSearch: string, gridPins: ide::GridPin[] }

/// A node the user has dragged onto a grid cell, identified by FQN. Carried inside
/// `LayoutTweaks`; honoured only under experimental grid placement.
public data GridPin { fqn: string, row: number, col: number }

/// The find-references result for the symbol under the caret: the symbol's FQN, a
/// human title, and every occurrence across the workspace.
public data References { fqn: string, title: string, occurrences: ide::Occurrence[] }

/// One occurrence of a symbol: the module it lies in, its line/column span, the
/// source line text with the match offsets within it, and whether it is the
/// declaration site.
public data Occurrence { fqn: string, line: number, col: number, endLine: number, endCol: number, text: string, matchStart: number, matchEnd: number, decl: bool }

/// One occurrence the user chose to rename, keyed by the module FQN and the
/// 1-based line/column an `ide::Occurrence` reported. The rename rewrites only
/// the selected occurrences, not every match.
public data RenameSelection { fqn: string, line: number, col: number }

/// One module rewritten by a rename: its FQN and new source text.
public data RenamedSource { fqn: string, source: string }

/// One file of the rendered documentation site: its site-relative path and
/// contents.
public data RenderedFile { path: string, contents: string }

/// The doc-site build input: the manifest plus each authored page's Markdown,
/// loaded by the host. Field detail is the wasm boundary's concern.
public data DocConfig;

/// One row of the workspace outline: a node's FQN, simple name, C4 kind,
/// containment parent (absent on roots), whether it is a triggered flow entry,
/// its `///` summary (absent when undocumented), and its declaration line/column.
public data OutlineNode { fqn: string, name: string, kind: string, parent: Option<string>, triggered: bool, summary: Option<string>, line: number, col: number }

/// The author's AI-completion provider settings, persisted in the browser: the
/// feature toggle, the chosen preset (`"ollama"`, `"openai"`, or `"custom"` —
/// the presets pin the endpoint and wire shape so setup is pick-and-go), the
/// OpenAI-compatible endpoint, the bring-your-own API key (stored in
/// localStorage, sent only to the configured endpoint), the model id, and the
/// wire shape (`"fim"` for a native fill-in-the-middle route, `"chat"` for the
/// chat-completions fallback).
public data LlmSettings { enabled: bool, provider: string, baseUrl: string, apiKey: string, model: string, mode: string }

/// A classified completion-provider failure: `kind` is `"network"` (endpoint
/// unreachable or CORS-blocked), `"auth"` (401/403), `"notFound"` (404 route or
/// model), `"timeout"`, or `"http"` (any other non-OK status); `message` states
/// what failed and `hint` names the fix for the configured provider (e.g. the
/// `OLLAMA_ORIGINS` command for a CORS-blocked local Ollama).
public data ProviderError { kind: string, message: string, hint: string }

/// The assembled fill-in-the-middle request: the windowed buffer text before and
/// after the caret, and the cached grammar primer that steers a general model to
/// emit valid PseudoScript.
public data FimPrompt { prefix: string, suffix: string, primer: string }

/// Why a folder pick yielded no workspace: the picker failed — the API missing,
/// blocked by permission policy, or denied by the embedder. Distinct from a
/// user cancel, which is silent: a cancel is the user's choice, a failure is
/// the product's to explain.
public data PickError { message: string }

// === Layer 1 — the IDE session: the one typed wasm ========================

/// `crates/pseudoscript-ide` — the IDE application, Rust compiled to a single
/// wasm. It owns the workspace state and is the whole browser API: the host
/// pushes modules in (`mount`/`setSource`) and pulls every answer out as a
/// typed value — the session never calls the DOM, CodeMirror, or the File
/// System Access API. It delegates language intelligence to `lsp_core` and
/// `model::Checks`, diagrams to `emit::Projector`, the 3D universe to
/// `universe::Adapter`, and the doc site to `doc::SiteBuilder` — each a Rust
/// library linked in, never a separate wasm. The one outbound seam is the doc
/// build's SSR render callback the host supplies. Everything here is Rust.
public container IdeSession for context::Pseudoscript {
  /// Replace the held workspace: the consumer's modules and the resolved
  /// dependency externals (§8.3). Re-parses every module and invalidates the
  /// memoised workspace/graph. Called on a structural change, not per edit.
  public mount(modules: model::WorkspaceModule[], externals: model::WorkspaceModule[]): void;

  /// Apply an edit to one module's buffer: re-parse only that module and
  /// invalidate the memoised workspace/graph, so the next query rebuilds once
  /// and the rest of the query burst reads the cache. An unchanged re-push is a
  /// no-op, keeping the cache warm.
  public setSource(fqn: string, text: string): void;

  /// The wasm build's version stamp, for the host's about/diagnostics surface.
  public version(): string;
}

/// The in-memory project the session holds: the parsed modules keyed by FQN (an
/// open buffer overlays via `setSource`), the dependency externals, and the
/// memoised resolved workspace + graph — invalidated by any mutation, rebuilt
/// once for the query burst between keystrokes. Edits never leave the tab; an
/// explicit save writes through the host's file handles, not this session.
public component Workspace for ide::IdeSession {
  /// Resolve a workspace's vendored git dependencies (§8.3) into dependency-name
  /// -prefixed modules — the externals `mount` takes — reusing the same
  /// resolution the native loader uses (`model::Deps`).
  dependencyModules(lockToml: string, vendored: ide::VendoredInput[], local: ide::LocalInput[]): model::WorkspaceModule[];

  /// The memoised resolved workspace with the externals bound — the resolution
  /// input every cursor query reads; rebuilt on first use after a mutation.
  heldWorkspace(): model::Workspace;
}

/// The language session: diagnostics, completion, hover, go-to, references,
/// rename, outline, folding, and semantic tokens over the held workspace, every
/// answer delegated to the pure toolchain logic (`model::Checks` for diagnostics,
/// `lsp_core` for cursor features) with the dependency externals bound. Every
/// answer is a typed value the host applies — the session pushes nothing at the
/// editor.
public component LanguageSession for ide::IdeSession {
  /// Workspace-wide diagnostics, each module's problems attributed to it and
  /// checked against the dependency externals (§8.3) — what the editor adapter
  /// marks in the gutter after every edit.
  public diagnostics(): model::ModuleDiagnostics[] {
    return checkAgainstExternals(heldModules(), heldExternals())
  }
  /// Check every module with the dependency modules bound as externals (§8.3), so
  /// a `dep::module::Node` reference resolves — the externals-aware counterpart of
  /// `model::Model.checkWorkspaceModules`.
  checkAgainstExternals(modules: model::WorkspaceModule[], external: model::WorkspaceModule[]): model::ModuleDiagnostics[];
  /// The held modules and dependency externals the session checks.
  heldModules(): model::WorkspaceModule[];
  heldExternals(): model::WorkspaceModule[];
  /// Parse and statically check one buffer — the editor's per-keystroke linter.
  check(source: string): syntax::Diagnostic[] {
    return model::Model.check(source)
  }
  /// Completions at a byte offset, resolved across the workspace and its
  /// externals, for the editor's completion source.
  complete(moduleFqn: string, offset: number): ide::Completion[];
  /// Markdown hover for the symbol under the caret, computed through the
  /// `lsp_core` toolchain over the held workspace. None when the cursor rests on
  /// no resolvable symbol — the adapter then shows no tooltip.
  hover(moduleFqn: string, offset: number): Option<lsp_core::Hover>;
  /// The held source buffer of one module, the text the cursor offset indexes into.
  heldSource(moduleFqn: string): string;
  /// Map a byte offset to the `lsp_core` caret position the handlers take (the
  /// boundary's offset→UTF-16-position conversion).
  caretPosition(src: string, offset: number): lsp_core::Position;
  /// Go-to-definition: the FQN the identifier under the caret points at, or absent
  /// when the cursor rests on no resolvable symbol.
  definition(moduleFqn: string, offset: number): Option<string>;
  /// Every occurrence of the symbol under the caret across the workspace, for the
  /// editor's reference highlighting, or absent when the cursor rests on no
  /// resolvable symbol.
  references(moduleFqn: string, offset: number): Option<ide::References>;
  /// Rename the symbol under the caret, rewriting only the user-chosen
  /// `selected` occurrences and returning each rewritten module's new source.
  renameApply(moduleFqn: string, offset: number, newName: string, selected: ide::RenameSelection[]): ide::RenamedSource[];
  /// The workspace symbol outline — the structure tree the editor's outline panel
  /// draws.
  outline(): ide::OutlineNode[];
  /// The foldable regions of one buffer (node bodies, doc blocks).
  foldingRanges(source: string): lsp_core::Range[];
  /// Delta-encoded semantic tokens for AST-aware highlighting (one buffer).
  semanticTokens(source: string): string;
  /// Canonical formatting, the same transform as `pds fmt` (one buffer).
  format(source: string): string;
}

/// Diagram projection: builds the workspace graph and projects a view to the
/// JSON `Scene` via `emit::Projector`; the host's canvas draws it. The wasm
/// surface carries only the JSON scene and layout — SVG and PNG are export
/// concerns of the canvas (PNG rasterised in the browser), and the static SVG
/// form is a CLI/doc concern of the `emit` crate, not exposed here.
public component Diagrams for ide::IdeSession {
  /// Project a view of the held workspace to the layout-ready JSON `Scene` —
  /// the notation-neutral geometry the interactive canvas draws from.
  public emitScene(view: emit::View, target: string): emit::Scene;
  /// Project the fitting view for a single symbol (a system/container's C4
  /// sub-view, a callable's sequence, a data type's entity view) — the IDE's
  /// "show this symbol" action.
  public symbolScene(fqn: string): emit::Scene;
  /// Position a projected scene into absolute coordinates under the UI's layout
  /// tweaks (which carry the drag-to-pin cells): a C4 scene through `emit`'s
  /// tweak-aware placement into an `emit::C4Layout`, a sequence scene through
  /// the `layout` engine — returned as the opaque layout JSON the canvas draws.
  public layoutScene(scene: emit::Scene, tweaks: ide::LayoutTweaks): string;
}

/// The doc-site builder: renders the whole site in-browser through the same
/// `pseudoscript-doc` crate `pds doc` runs, driving SSR through a render
/// callback the host supplies (the browser's JS engine is the SSR engine) — so
/// the IDE writes the exact site the CLI ships, health page included. The site
/// builds to the opened folder's `target/doc/` only; an in-memory workspace is
/// told to open a folder first (no blob-preview path).
public component Docs for ide::IdeSession {
  /// Build the documentation site for the held workspace: the typed config in,
  /// every rendered file out. The session checks the held modules itself and
  /// prepares the diagnostics for the doc face (the wasm signature is
  /// unchanged — diagnostics never cross the boundary). SSR crosses to the
  /// host's render callback.
  render(config: ide::DocConfig): ide::RenderedFile[] {
    perModule = model::ModuleDiagnostics[] from model::Model.checkWorkspaceModules(heldDocModules(), heldExternals())
    prepared = doc::DiagnosticInput[] from doc::Doc.prepareDiagnostics(heldDocModules(), perModule)
    return renderWith(config, prepared)
  }

  /// The held workspace's own modules, the check input.
  heldDocModules(): model::WorkspaceModule[];

  /// The held dependency modules, the check's external context.
  heldExternals(): model::WorkspaceModule[];

  /// Drive the doc face with the prepared diagnostics, crossing SSR to the
  /// host's render callback.
  renderWith(config: ide::DocConfig, diagnostics: doc::DiagnosticInput[]): ide::RenderedFile[];
  /// Parse a `pds.toml` into the doc manifest the host reads to load pages.
  manifest(toml: string): string;
  /// The shared client-side bundle every doc page loads once — the same SSR
  /// bundle `pds doc` ships, so the IDE-built site matches the CLI exactly.
  ssrBundle(): string;
}

/// The 3D universe: builds the software graph from the held workspace and flattens
/// it to a snapshot the `ForceGraph` renders, with the entry-point flows traced
/// in Rust. Delegates to the `universe` crate; the wasm surface carries only the
/// flat snapshot and flows — positions are the renderer's.
public component Universe for ide::IdeSession {
  /// The 3D-view snapshot of the held workspace: structural nodes with
  /// containment and directed traffic-weighted relationships, no positions.
  universe(): ide::UniverseSnapshot {
    graph = universe::SoftwareGraph from universe::Universe.build(heldModules())
    return toSnapshot(universe::Universe.snapshot(graph))
  }

  /// The entry-point flows of the held workspace, traced and lifted by the
  /// universe crate — the filaments the ForceGraph animates. Replaces the IDE's
  /// former client-side sequence-walking, so doc site and IDE share one tracer.
  universeFlows(): universe::FlowDef[] {
    graph = model::Graph from model::Model.graph(heldModules())
    return universe::Universe.flows(graph)
  }

  /// The held workspace's own modules, the universe input.
  heldModules(): model::WorkspaceModule[];

  /// Carry a `universe::Snapshot` across the typed boundary as the IDE's snapshot.
  toSnapshot(snapshot: universe::Snapshot): ide::UniverseSnapshot;
}

// === Layer 2 — the JS adapters (the only JavaScript) =====================

/// `web-ide` — the IDE at `ide.pdscript.dev`: a SvelteKit shell on Cloudflare
/// Workers static assets. Pure glue — it loads the one wasm bundle and binds the
/// adapters to the session's ports. It holds no language logic.
public container WebIde for context::Pseudoscript {
  /// Open the IDE in the browser tab: load the wasm (IdeSession) and bootstrap
  /// the adapters.
  public open(): void {
    ide::Bootstrap.start()
  }

  /// Open the bundled language reference in-product (Help menu) — the same
  /// version-pinned spec the authoring-skill zip vendors, so an author never
  /// leaves the IDE to look up syntax.
  openLanguageReference(): void;
}

/// The file-system adapter over the browser File System Access API: directory
/// picker, recursive walk for `.pds` modules, deriving each module's flat FQN
/// from its path (LANG.md §8.1, ADR-031), `pds.lock` + `pds_modules/` reads for
/// dependency externals, and per-file read/write through handles. The only place
/// FS-Access specifics live; it pushes what it reads into the session via
/// `mount`.
public component FsAccessAdapter for ide::WebIde {
  /// Show the native directory picker. Ok(true) = a folder was picked and
  /// retained; Ok(false) = the user cancelled; Err = the picker failed (API
  /// missing, permission policy, embedder denial) — the caller surfaces it.
  pickFolder(): Result<bool, ide::PickError>;

  /// Walk the picked directory for the project's own modules.
  readModules(): model::WorkspaceModule[];
  /// Read `pds.lock` and the dependency files under `pds_modules/` (deriving each
  /// module's FQN from its path, LANG.md §8.1), then resolve externals via the
  /// session.
  readDependencies(): model::WorkspaceModule[] {
    lock = string from readLock()
    vendored = ide::VendoredInput[] from readVendored()
    local = ide::LocalInput[] from noLocalSources()
    return ide::Workspace.dependencyModules(lock, vendored, local)
  }
  /// The consumer's `pds.lock` text, blank when absent.
  readLock(): string;
  /// The vendored git-dependency files walked from `pds_modules/`, each tagged
  /// with its slug, derived FQN, and source.
  readVendored(): ide::VendoredInput[];
  /// Always empty: local-source dependencies (ADR-026) resolve a sibling path
  /// outside the picked directory, which the File System Access API cannot read,
  /// so the browser resolves only vendored git dependencies and passes no
  /// local-source inputs to `dependencyModules`.
  noLocalSources(): ide::LocalInput[];
  /// Write one module's text back through its file handle.
  writeModule(fqn: string, text: string): void;
}

/// The editor adapter over CodeMirror 6: the text/cursor model, the completion
/// source, the hover tooltip, the diagnostics gutter, and edit events forwarded
/// into the session. The only place CodeMirror specifics live — it drives the
/// session and applies the typed values it gets back.
public component CodeMirrorAdapter for ide::WebIde {
  /// On each edit: push the buffer into the session, re-query the workspace
  /// diagnostics, and mark them in the gutter.
  onEdit(fqn: string, text: string): void {
    ide::IdeSession.setSource(fqn, text)
    diags = model::ModuleDiagnostics[] from ide::LanguageSession.diagnostics()
    markProblems(diags)
  }
  /// The completion source: ask the session for items at the caret. A `.`/`::`
  /// boundary opens the popup with no prefix typed.
  requestCompletion(moduleFqn: string, offset: number): ide::Completion[] {
    return ide::LanguageSession.complete(moduleFqn, offset)
  }
  /// On hover: ask the session for the symbol's Markdown; none shows no tooltip.
  requestHover(moduleFqn: string, offset: number): void {
    result = Option<lsp_core::Hover> from ide::LanguageSession.hover(moduleFqn, offset)
    if (result.isNone) {
      return
    }
    showTooltip(result.value.contents)
  }
  /// Mark the problems CodeMirror shows in its gutter.
  markProblems(diags: model::ModuleDiagnostics[]): void;
  /// Show a Markdown hover tooltip.
  showTooltip(markdown: string): void;
}

/// The author's AI-completion settings, persisted to browser localStorage and
/// edited through the Settings dialog's "AI Completion" tab. Bring-your-own key:
/// it never leaves the tab except on requests to the configured endpoint.
/// Setup is preset-first: picking a provider applies its pinned endpoint and
/// wire shape, so only the Custom preset exposes the raw fields. The store also
/// carries the session's last completion failure (never persisted) so the
/// status chip and the settings tab can show why ghost text is bailing.
component LlmSettingsStore for ide::WebIde {
  /// The persisted settings (defaults when nothing is stored).
  current(): ide::LlmSettings;
  /// Whether ghost-text completion is switched on and configured — the OpenAI
  /// preset additionally requires a non-empty API key.
  isEnabled(): bool;
  /// Persist an edit from the settings tab.
  save(settings: ide::LlmSettings): void;
  /// Apply a provider preset: its pinned endpoint, wire shape, and default
  /// model become the active settings in one edit.
  applyPreset(provider: string): void {
    preset = ide::LlmSettings from presetFor(provider)
    save(preset)
  }
  /// The pinned settings for a preset id: `ollama` → the local daemon over
  /// chat with no key; `openai` → the hosted endpoint over chat, key required;
  /// `custom` → the current fields untouched.
  presetFor(provider: string): ide::LlmSettings;
  /// Record the latest classified completion failure for the status surfaces.
  reportFailure(err: ide::ProviderError): void;
  /// Clear the failure once a request succeeds.
  clearFailure(): void;
  /// The session's last completion failure, if any.
  lastFailure(): Option<ide::ProviderError>;
  /// Record that the provider answered but the suggestion was dropped — a
  /// blank answer. The chip says so instead of staying silent.
  noteDrop(reason: string): void;
  /// Clear the drop note once a suggestion renders.
  clearDrop(): void;
  /// The most recent drop reason, if the last answer never rendered.
  lastDropReason(): Option<string>;
}

/// Provider-agnostic completion client: one `complete` contract over
/// OpenAI-compatible HTTP, so one client covers Codestral, OpenRouter, Together,
/// Ollama, and vLLM. Stateless — the caller hands it the settings snapshot and
/// owns cancellation (`GhostText` aborts the in-flight request on the next
/// keystroke; the client honours the abort). Every failure comes back as a
/// classified `ProviderError`, so the caller can surface why a request bailed.
component FimClient for ide::WebIde {
  /// Route the prompt by the configured wire shape: a native fill-in-the-middle
  /// route when the provider has one, else a FIM-shaped chat request.
  complete(prompt: ide::FimPrompt, settings: ide::LlmSettings): Result<string, ide::ProviderError> {
    fim = bool from usesNativeFim(settings)
    if (fim) {
      return ide::LlmProvider.fimComplete(prompt, settings.model)
    }
    return ide::LlmProvider.chatComplete(prompt, settings.model)
  }
  /// Whether the configured mode selects the native FIM route.
  usesNativeFim(settings: ide::LlmSettings): bool;
  /// The provider's live model ids (`GET /models`) — what populates the
  /// settings tab's model dropdown for the Ollama and OpenAI presets.
  listModels(settings: ide::LlmSettings): Result<string[], ide::ProviderError> {
    return ide::LlmProvider.listModels()
  }
  /// Round-trip probe for the settings tab's "Test connection": list the
  /// models, then ask for a one-token completion — the first failure comes
  /// back classified, with its fix hint, instead of a silent bail.
  testConnection(settings: ide::LlmSettings): Result<string[], ide::ProviderError> {
    models = Result<string[], ide::ProviderError> from listModels(settings)
    if (models.isErr) {
      return Err(models.error)
    }
    probe = ide::FimPrompt from probePrompt()
    answer = Result<string, ide::ProviderError> from complete(probe, settings)
    if (answer.isErr) {
      return Err(answer.error)
    }
    return Ok(models.value)
  }
  /// The minimal one-token prompt the connection test sends.
  probePrompt(): ide::FimPrompt;
}

/// Inline ghost-text completion over CodeMirror 6, beside the grammar dropdown:
/// structural candidates stay local and deterministic in `CodeMirrorAdapter`;
/// the remote model supplies only multi-token greyed text. CodeMirror has no
/// native inline-suggestion UI, so this is a custom view plugin rendering a
/// widget decoration at the caret — Tab accepts, Esc dismisses, any edit clears.
component GhostText for ide::WebIde {
  /// On an idle pause in typing: assemble the context, ask the provider, and
  /// show the suggestion as-is — the author judges it, and the live
  /// diagnostics flag any syntax error the moment it is accepted. Every
  /// non-rendering outcome is reported to the settings store — a provider
  /// failure as the classified error, a blank answer as a drop note — so the
  /// status chip explains the silence; none of it ever blocks typing.
  suggest(moduleFqn: string, offset: number): void {
    enabled = bool from ide::LlmSettingsStore.isEnabled()
    if (!enabled) {
      return
    }
    settings = ide::LlmSettings from ide::LlmSettingsStore.current()
    prompt = ide::FimPrompt from assemble(moduleFqn, offset)
    raw = Result<string, ide::ProviderError> from ide::FimClient.complete(prompt, settings)
    if (raw.isErr) {
      ide::LlmSettingsStore.reportFailure(raw.error)
      return
    }
    ide::LlmSettingsStore.clearFailure()
    blank = bool from isBlank(raw.value)
    if (blank) {
      ide::LlmSettingsStore.noteDrop("empty")
      return
    }
    ide::LlmSettingsStore.clearDrop()
    show(raw.value)
  }
  /// The provider context: the windowed buffer around the caret plus the cached
  /// grammar primer.
  assemble(moduleFqn: string, offset: number): ide::FimPrompt {
    window = string from windowAround(moduleFqn, offset)
    symbols = ide::OutlineNode[] from ide::LanguageSession.outline()
    primer = string from grammarPrimer()
    return ide::FimPrompt from { window, symbols, primer }
  }
  /// The capped prefix/suffix slice of the buffer around the caret.
  windowAround(moduleFqn: string, offset: number): string;
  /// The cached compact grammar summary (LANG.md §10) plus a worked
  /// micro-example — what steers a general model to emit valid `.pds`.
  grammarPrimer(): string;
  /// Whether the answer carries nothing to insert (whitespace only).
  isBlank(raw: string): bool;
  /// Render the greyed inline text at the caret.
  show(raw: string): void;
}

/// The author's configured OpenAI-compatible completion provider — hosted
/// (OpenAI, Codestral, OpenRouter, Together) or local (Ollama, vLLM). External:
/// the IDE only speaks its HTTP API; transport and HTTP failures surface as
/// classified `ProviderError`s.
public system LlmProvider {
  /// Native fill-in-the-middle completion (`/v1/fim/completions`).
  fimComplete(prompt: ide::FimPrompt, model: string): Result<string, ide::ProviderError>;
  /// Chat-completions fallback (`/v1/chat/completions`) with a FIM-shaped prompt.
  chatComplete(prompt: ide::FimPrompt, model: string): Result<string, ide::ProviderError>;
  /// The available model ids (`/v1/models`) — a local Ollama answers with the
  /// models the host has pulled.
  listModels(): Result<string[], ide::ProviderError>;
}

/// The diagram canvas: draws the **JSON** `Scene` interactively (Svelte Flow
/// pan/zoom over geometry positioned by `emit`'s layout engine for C4, a
/// depth-collapsible timeline for sequences), and exports the current view as
/// **PNG or SVG**, both produced in the browser from the drawn diagram. JSON is
/// the draw format; no diagram image crosses the wasm surface. The editor
/// port's diagram seam binds to this.
public component DiagramCanvas for ide::WebIde {
  /// Draw the JSON scene onto the interactive canvas.
  render(scene: emit::Scene): void;
  /// Export the current view as a PNG, rasterised in the browser from the drawn
  /// diagram.
  exportPng(): void;
  /// Export the current view as an SVG, serialised in the browser from the
  /// drawn diagram — distinct from the `emit` crate's static SVG, which stays a
  /// CLI/doc path.
  exportSvg(): void;
}

/// Boots the IDE in a browser tab: load the one wasm bundle (IdeSession), then
/// restore the URL hash's workspace — a share link mounts in memory and needs
/// no disk — or fall back to the launcher. File System Access support gates
/// only the disk features (open folder, save, watch): without it those actions
/// are disabled with a notice, while share links and the bundled examples
/// still open.
public component Bootstrap for ide::WebIde {
  /// Restore from the hash when it carries a workspace; else show the launcher.
  start(): void {
    restored = bool from restoreFromHash()
    if (!restored) {
      ide::Launcher.show()
    }
  }

  /// Decode and mount the URL hash's embedded workspace (a share link), in
  /// memory, session-only; false when the hash carries none. A corrupt payload
  /// surfaces a notification and falls back to the launcher.
  restoreFromHash(): bool;
}

/// The bundled example catalogue, discovered at build time from the samples
/// folder (one folder per example: meta.json, the `.pds` modules, `pds.toml`,
/// doc pages). Each entry doubles as a New-project template and as an
/// in-memory workspace.
public component Samples for ide::WebIde {
  /// One example in the in-memory workspace shape the session mounts — the
  /// same shape a decoded share link yields.
  workspaceOf(id: string): ide::BrowserWorkspace;
}

/// The project launcher — the first surface. Offers the recents, open-a-folder,
/// New Project, and the bundled examples. Examples and share links mount in
/// memory and need no disk; only the disk actions gate on File System Access
/// support. Dismissible, so the menus, help, and settings stay reachable
/// without a project.
public component Launcher for ide::WebIde {
  /// Present the launcher.
  show(): void;

  /// Open one bundled example in memory, session-only — the zero-commitment
  /// route to a working model: no name, no folder, no disk. Exactly the mount
  /// path a share link uses; saving later upgrades it to a real folder.
  openExample(id: string): void {
    ws = ide::BrowserWorkspace from ide::Samples.workspaceOf(id)
    ide::IdeSession.mount(ws.modules, ws.externals)
  }

  /// Open a real folder from disk (File System Access; disk-gated). The pick
  /// is three-way: a failure surfaces inline where the user acted, a cancel is
  /// silent, and a picked folder mounts. Cancel and failure are never
  /// conflated — swallowing a failure leaves a dead control.
  openFolder(): void {
    picked = Result<bool, ide::PickError> from ide::FsAccessAdapter.pickFolder()
    if (picked.isErr) {
      showPickError(picked.error)
      return
    }
    if (!picked.value) {
      return
    }
    mods = model::WorkspaceModule[] from ide::FsAccessAdapter.readModules()
    deps = model::WorkspaceModule[] from ide::FsAccessAdapter.readDependencies()
    ide::IdeSession.mount(mods, deps)
  }

  /// Render a pick failure inline at the control that triggered it, naming the
  /// cause.
  showPickError(err: ide::PickError): void;
}

// === Invariants ==========================================================

/// The IDE is one Rust crate compiled to one typed wasm; the toolchain is linked
/// in as libraries, not consumed as a second wasm.
feature OneTypedWasm for ide::IdeSession {
  given "the IDE application compiled to WebAssembly as `pseudoscript-ide`"
  when "it needs language intelligence, a diagram, the 3D universe, or the doc site"
  then "it calls the `lsp_core`, `model`, `emit`, `universe`, and `doc` crates as linked Rust libraries"
  and "exposes one typed surface to JavaScript — DTOs `tsify` projects to TS, not JSON strings"
  but "there is no second wasm, so no bridge can drift from the app that uses it"
}

/// The 3D universe is built in Rust and crosses as a flat snapshot.
feature UniverseDrawsFromSnapshot for ide::Universe {
  given "the held workspace"
  when "the IDE opens the 3D relationship view"
  then "the universe crate builds the software graph and flattens it to a snapshot"
  and "the snapshot crosses the typed boundary as nodes and directed weighted edges"
  but "no positions cross — the browser's force layout places the nodes"
}

/// The C4 canvas drives `emit`'s layout under the UI's tweaks and pins.
feature LayoutTweaksDriveTheCanvas for ide::Diagrams {
  given "a C4 view open on the canvas and the UI's layout toggles"
  when "the view is laid out"
  then "the session passes the tweaks and any drag-to-pin cells to emit's C4 placement"
  and "the canvas redraws from the re-positioned scene"
}

/// JavaScript exists only in the adapters plus the host's path→FQN derivation;
/// all language and projection logic is Rust.
feature JsOnlyAtAdapters for ide::WebIde {
  given "the IDE session, the language queries, and diagram projection all in Rust"
  when "the application touches the file system or the editor surface"
  then "an adapter — `FsAccessAdapter`, `CodeMirrorAdapter` — pushes state into the typed session and applies the values it returns"
  and "those adapters are the only JavaScript: File System Access and CodeMirror specifics live there"
  but "the FS adapter also derives each module's flat FQN from its path (LANG.md §8.1, ADR-031) — the one workspace rule the host runs before pushing modules to the Rust core"
}

/// A cross-workspace reference resolves because dependencies load as externals.
feature DependenciesResolveAsExternals for ide::LanguageSession {
  given "a workspace that declares a git dependency, vendored under `pds_modules/`"
  when "the file-system port reads `pds.lock` + `pds_modules/` and the session resolves them"
  then "every language query binds the dependency modules as externals (§8.3)"
  and "a `dep::module::Node` reference resolves — checked, hovered, and completed"
  but "the dependency's own modules are never offered as raw `pds_modules::…` paths"
}

/// A projected diagram is drawn from the JSON scene; no diagram image crosses
/// the IDE's wasm surface — PNG and SVG exports are produced client-side.
feature DiagramDrawsFromJsonScene for ide::DiagramCanvas {
  given "a projected view of the held workspace"
  when "the IDE draws or exports a diagram"
  then "the JSON `Scene` from the session's `emitScene` draws the interactive canvas — the same geometry the HTML doc site's client islands draw"
  and "PNG and SVG exports are produced in the browser from the drawn diagram"
  but "no image crosses the IDE wasm — its surface carries only the JSON scene; the `emit` crate's static SVG remains the CLI/doc path"
}

/// Ghost text comes from the configured provider, rendered as-is for the
/// author to judge.
feature GhostTextSuggests for ide::GhostText {
  given "AI completion enabled with a configured OpenAI-compatible provider"
  when "the author pauses typing"
  then "the windowed prefix/suffix and the grammar primer go to the provider"
  and "the suggestion renders as greyed inline text — Tab accepts, Esc dismisses"
  but "the suggestion is the author's to judge — accepting one with a syntax error lights the live diagnostics — and a provider failure surfaces on the AI status chip with the reason; it never blocks typing"
}

/// Setup is preset-first; the connection test explains a failure instead of
/// leaving the author guessing.
feature GuidedProviderSetup for ide::LlmSettingsStore {
  given "the Settings dialog's AI Completion tab"
  when "the author picks the Ollama or OpenAI preset"
  then "the endpoint and wire shape are pinned by the preset — no raw URL to type"
  and "the model dropdown fills from the provider's live model list"
  and "Test connection round-trips the provider and reports success or the classified failure with its fix hint"
  but "the Custom preset still exposes every field for any OpenAI-compatible endpoint"
}

/// The remote model augments, never replaces, the local grammar completer.
feature StructuralCompletionStaysLocal for ide::GhostText {
  given "the grammar dropdown completer answering from the wasm session"
  when "AI completion is enabled beside it"
  then "structural candidates stay local and deterministic"
  and "the remote model supplies only multi-token inline suggestions"
  but "with AI completion off or unconfigured, the editor behaves exactly as before"
}

/// Examples open in memory — value before any commitment.
feature ExamplesNeedNoDisk for ide::Launcher {
  given "a first-time visitor on the launcher"
  when "they open a bundled example"
  then "it mounts in memory with no name, no folder, and no disk permission"
  and "the same session-only mount path a share link uses carries it"
  but "saving to a folder later upgrades it to a real on-disk workspace"
}

/// Missing File System Access disables disk features, never the IDE.
feature DiskGatesOnlyDiskFeatures for ide::Bootstrap {
  given "a browser without the File System Access API (Firefox, Safari)"
  when "the IDE boots"
  then "share links and bundled examples still open in memory"
  and "the disk actions — open folder, save, watch — are disabled with a notice naming the supported browsers"
  but "no full-screen wall blocks the product"
}

/// A pick failure is surfaced; a cancel is silent.
feature PickerFailureSurfaced for ide::Launcher {
  given "the native folder picker invoked from Open or New Project"
  when "it closes without a folder"
  then "a user cancel changes nothing, silently"
  but "a failure — blocked API, permission policy, embedder denial — renders inline at the control with the cause"
}

/// Editing a model in the browser checks and redraws it live, with no backend.
feature EditInBrowser for ide::WebIde {
  given "a `.pds` module open in the browser IDE"
  when "the author edits it through the CodeMirror adapter"
  then "the edit drives the Rust session, which re-checks against the externals"
  and "diagnostics and the projected C4 or sequence diagram update live"
  but "nothing is sent to a server"
}
